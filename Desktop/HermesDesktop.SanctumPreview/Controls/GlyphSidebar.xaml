<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SanctumPreview.Controls.GlyphSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Width="64" Background="#080B10" BorderBrush="#161C25" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0" Text="&#x2727;" FontSize="22" Foreground="{StaticResource AppAccentBrush}"
                       HorizontalAlignment="Center" Margin="0,20,0,24"/>
            <ItemsControl x:Name="NavItems" Grid.Row="1" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Grid Grid.Row="2" Margin="0,0,0,16" HorizontalAlignment="Center">
                <Button x:Name="SettingsButton" Click="OnSettingsClick"
                        Width="44" Height="44" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="12">
                    <TextBlock Text="&#x2699;" FontSize="18" Foreground="#3A4555"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
