<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HermesDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HermesDesktop"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <!-- ═══ Fonts ═══ -->
            <FontFamily x:Key="PlayfairDisplayFont">ms-appx:///Assets/Fonts/PlayfairDisplay.ttf#Playfair Display</FontFamily>
            <FontFamily x:Key="InterFont">ms-appx:///Assets/Fonts/Inter-Regular.ttf#Inter</FontFamily>
            <FontFamily x:Key="JetBrainsMonoFont">ms-appx:///Assets/Fonts/JetBrainsMono.ttf#JetBrains Mono</FontFamily>
            <!-- ═══ Brushes — Sanctum v2 palette ═══ -->
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#EAEEF4" />
            <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#0B0E14" />
            <SolidColorBrush x:Key="AppPaneBackgroundBrush" Color="#080B10" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#0E1218" />
            <SolidColorBrush x:Key="AppInsetBrush" Color="#0C1018" />
            <SolidColorBrush x:Key="AppPanelBrush" Color="#0E1420" />
            <SolidColorBrush x:Key="AppStrokeBrush" Color="#161C25" />
            <SolidColorBrush x:Key="AppSubtleStrokeBrush" Color="#12181F" />
            <!-- Hermes gradient palette: caramel → goldenrod → golden yellow -->
            <SolidColorBrush x:Key="AppAccentBrush" Color="#D4A017" />
            <SolidColorBrush x:Key="AppAccentTextBrush" Color="#FFD700" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#4A5565" />
            <SolidColorBrush x:Key="AppTextMutedBrush" Color="#2A3545" />
            <!-- Node-type semantic colors -->
            <SolidColorBrush x:Key="SessionGreenBrush" Color="#49C27D" />
            <SolidColorBrush x:Key="MemoryPurpleBrush" Color="#818CF8" />
            <SolidColorBrush x:Key="ToolOrangeBrush" Color="#FF8A65" />
            <SolidColorBrush x:Key="SkillRedBrush" Color="#E05555" />
            <SolidColorBrush x:Key="GhostBrush" Color="#2A3545" />
            <SolidColorBrush x:Key="FileGreenBrush" Color="#5A7555" />
            <LinearGradientBrush x:Key="AppUserBubbleBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E1A0A" Offset="0.0" />
                <GradientStop Color="#2A2210" Offset="0.5" />
                <GradientStop Color="#332A0F" Offset="1.0" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AppHeroAccentBrush" Color="#FFD700" />
            <SolidColorBrush x:Key="AppAccentDarkBrush" Color="#C68E17" />
            <SolidColorBrush x:Key="AppOutlineBrush" Color="#3A3A00" />
            <LinearGradientBrush x:Key="AppAccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#C68E17" Offset="0.0" />
                <GradientStop Color="#D4A017" Offset="0.5" />
                <GradientStop Color="#FFD700" Offset="1.0" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AppAccentGradientVerticalBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFD700" Offset="0.0" />
                <GradientStop Color="#D4A017" Offset="0.5" />
                <GradientStop Color="#C68E17" Offset="1.0" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ConnectionOnlineBrush" Color="#49C27D" />
            <SolidColorBrush x:Key="ConnectionOfflineBrush" Color="#FF8A65" />

            <!-- ═══ Card Styles ═══ -->
            <Style x:Key="SurfaceCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="18" />
            </Style>
            <Style x:Key="InsetCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AppInsetBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14" />
            </Style>
            <!-- ═══ Typography — Sanctum v2 ═══ -->
            <Style x:Key="PageEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFont}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="{StaticResource AppAccentTextBrush}" />
                <Setter Property="CharacterSpacing" Value="200" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource PlayfairDisplayFont}" />
                <Setter Property="FontSize" Value="38" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#EAEEF4" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFont}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#3A4555" />
                <Setter Property="CharacterSpacing" Value="150" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="BodySecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="LabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFont}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#3A4555" />
                <Setter Property="CharacterSpacing" Value="50" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource PlayfairDisplayFont}" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="DataLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFont}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#2A3545" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
