<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HermesDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:HermesDesktop.Controls"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
            <!-- Glyph Sidebar -->
            <controls:GlyphSidebar x:Name="GlyphNav"
                                   NavigationRequested="OnGlyphNavRequested" />

            <!-- Content + Ambient Overlays -->
            <Grid Grid.Column="1">
                <Frame x:Name="ContentFrame" />
                <!-- Ambient buddy — visible on all pages -->
                <controls:BuddyOverlay HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,24,20"/>

                <!-- Ambient background glow -->
                <Canvas IsHitTestVisible="False" Opacity="0.7">
                    <Ellipse Width="1200" Height="800" Canvas.Left="-200" Canvas.Top="300">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#06D4A017" Offset="0" />
                                <GradientStop Color="Transparent" Offset="0.7" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>
            </Grid>
        </Grid>
    </Grid>
</Window>
