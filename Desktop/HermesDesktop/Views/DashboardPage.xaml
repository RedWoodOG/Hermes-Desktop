<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:HermesDesktop.Controls"
    Background="Transparent"
    Loaded="OnPageLoaded"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ Header ═══ -->
        <Grid Padding="48,28,48,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <!-- Eyebrow with decorative line -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="20" Height="1" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#D4A017" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="EyebrowText" Text="THE CROSSROADS"
                               Style="{StaticResource PageEyebrowTextStyle}"/>
                </StackPanel>

                <!-- Title -->
                <TextBlock x:Name="PageTitle" Text="Hermes"
                           Style="{StaticResource PageTitleTextStyle}"/>

                <!-- Subtitle -->
                <TextBlock x:Name="PageSubtitle" Text=""
                           FontFamily="{StaticResource InterFont}"
                           FontSize="13" Foreground="#4A5565" FontWeight="Light"/>

                <!-- Breadcrumb -->
                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="BRAIN"
                               FontFamily="{StaticResource JetBrainsMonoFont}"
                               FontSize="10" Foreground="#3A4555"/>
                    <TextBlock Text="▸" FontSize="10" Foreground="#1A2535"/>
                    <TextBlock x:Name="BreadcrumbWorkspace" Text=""
                               FontFamily="{StaticResource JetBrainsMonoFont}"
                               FontSize="10" Foreground="#3A4555"/>
                    <TextBlock Text="▸" FontSize="10" Foreground="#1A2535"/>
                    <TextBlock x:Name="BreadcrumbProject" Text=""
                               FontFamily="{StaticResource JetBrainsMonoFont}"
                               FontSize="10" Foreground="#D4A017"/>
                </StackPanel>
            </StackPanel>

            <!-- Zoom Controls -->
            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Width="36" Height="36" Padding="0" CornerRadius="10"
                        Background="#0E1420" BorderBrush="#1A2535"
                        Content="⬚" FontSize="16" Foreground="#4A5565"
                        ToolTipService.ToolTip="Full brain view"/>
                <Button Width="36" Height="36" Padding="0" CornerRadius="10"
                        Background="#10D4A017" BorderBrush="#60D4A017"
                        Content="⬥" FontSize="16" Foreground="#FFD700"
                        ToolTipService.ToolTip="Project view"/>
                <TextBlock Text="SCOPE"
                           FontFamily="{StaticResource JetBrainsMonoFont}"
                           FontSize="8" Foreground="#2A3545" CharacterSpacing="50"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Brain Graph Canvas ═══ -->
        <controls:BrainGraphCanvas x:Name="BrainCanvas" Grid.Row="1" Margin="32,0"/>

        <!-- ═══ Bottom Panel ═══ -->
        <Grid Grid.Row="2" Padding="48,0,48,24" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Project Vitals -->
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="PROJECT VITALS" Style="{StaticResource SectionTitleTextStyle}"/>
                    <Border Height="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="200">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#20161C25" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sessions -->
                    <Border Background="#0E1218" BorderBrush="#161C25" BorderThickness="1"
                            CornerRadius="14" Padding="16,16,20,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SESSIONS" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="StatSessions" Text="0"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                            <TextBlock x:Name="StatSessionsSub" Text=""
                                       Style="{StaticResource DataLabelTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tools -->
                    <Border Grid.Column="1" Background="#0E1218" BorderBrush="#161C25" BorderThickness="1"
                            CornerRadius="14" Padding="16,16,20,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="TOOLS" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="StatTools" Text="0"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource SessionGreenBrush}"/>
                            <TextBlock x:Name="StatToolsSub" Text=""
                                       Style="{StaticResource DataLabelTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Memories -->
                    <Border Grid.Column="2" Background="#0E1218" BorderBrush="#161C25" BorderThickness="1"
                            CornerRadius="14" Padding="16,16,20,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="MEMORIES" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock x:Name="StatMemories" Text="0"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Foreground="{StaticResource MemoryPurpleBrush}"/>
                            <TextBlock x:Name="StatMemoriesSub" Text=""
                                       Style="{StaticResource DataLabelTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Recent Journeys -->
            <StackPanel Grid.Column="1" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="RECENT JOURNEYS" Style="{StaticResource SectionTitleTextStyle}"/>
                    <Border Height="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="200">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#20161C25" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <ListView x:Name="JourneysList" Background="Transparent" SelectionMode="None" MaxHeight="140">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0C1018" BorderBrush="#12181F" BorderThickness="1"
                                    CornerRadius="10" Padding="10,10,16,10" Margin="0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Ellipse Width="6" Height="6" Fill="{Binding StatusColor}"
                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               FontSize="12" FontWeight="Medium" Foreground="#8A95A5"
                                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Meta}"
                                               FontSize="9" Foreground="#2A3545"
                                               FontFamily="{StaticResource JetBrainsMonoFont}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
