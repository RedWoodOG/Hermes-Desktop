<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.SessionPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <TextBlock x:Name="EmptyState" Visibility="Collapsed"
                   Text="No journeys yet.&#x0a;Start chatting to begin one."
                   FontFamily="{StaticResource JetBrainsMonoFont}" FontSize="10"
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" CharacterSpacing="100" Opacity="0.6"/>

        <ListView x:Name="SessionList" SelectionChanged="SessionList_SelectionChanged"
                  Background="Transparent" BorderThickness="0"
                  SelectionMode="Single" IsItemClickEnabled="True"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource AppSubtleStrokeBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="10,8,10,8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontFamily="{StaticResource InterFont}" FontSize="12"
                                               Foreground="{StaticResource AppTextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Text="{Binding MetaLine}"
                                           FontFamily="{StaticResource JetBrainsMonoFont}" FontSize="9"
                                           Foreground="{StaticResource AppTextMutedBrush}"
                                           CharacterSpacing="50" Margin="14,0,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                    Click="DeleteSession_Click" Tag="{Binding Id}"
                                    Background="Transparent" Foreground="{StaticResource AppTextMutedBrush}"
                                    BorderThickness="0" Padding="4" MinWidth="0" MinHeight="0"
                                    VerticalAlignment="Center" Opacity="0.6"
                                    ToolTipService.ToolTip="Delete journey"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
